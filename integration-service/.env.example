# Inactivity reminders and autoclose are disabled by default.
GLPI_TICKET_CREATE_TIMEOUT_MS=45000
INACTIVITY_AUTOCLOSE_ENABLED=false
INACTIVITY_REMINDER_MINUTES=3,5,10
INACTIVITY_AUTOCLOSE_MINUTES=30
INACTIVITY_JOB_INTERVAL_SECONDS=60

# AI supervisor quality analysis is local/Ollama only and disabled by default.
AI_SUPERVISOR_ENABLED=false
AI_SUPERVISOR_PROVIDER=disabled
AI_SUPERVISOR_MODEL=llama3.1
AI_SUPERVISOR_BASE_URL=http://127.0.0.1:11434
AI_SUPERVISOR_TIMEOUT_SECONDS=30
AI_SUPERVISOR_MAX_MESSAGES=30
AI_SUPERVISOR_MAX_CHARS=12000
AI_SUPERVISOR_DRY_RUN=true

# Controlled AI cloud/embeddings pilot. Disabled by default; never place real
# provider secrets here. Enable only in TEST/HOMOLOG with explicit LGPD/DPO gate.
AI_PILOT_CLOUD_ENABLED=false
AI_PILOT_EMBEDDINGS_ENABLED=false
AI_PILOT_PROVIDER=disabled
AI_PILOT_MODEL=pilot-disabled
AI_PILOT_MONTHLY_BUDGET_LIMIT=0
AI_PILOT_HARD_BUDGET_BLOCK=true
AI_PILOT_DPO_APPROVED=false
AI_PILOT_DIRECTOR_APPROVED=false
AI_PILOT_ADMIN_OPT_IN=false
AI_PILOT_INCIDENT_ACK=false
AI_PILOT_TEST_ENVIRONMENT_ONLY=true
AI_PILOT_ENVIRONMENT=test
AI_PILOT_TIMEOUT_SECONDS=45
AI_PILOT_RETRY_COUNT=1

# Meta webhook environment guard.
# Configure different values per environment. Never reuse production IDs in TEST.
ALLOWED_META_PHONE_NUMBER_IDS=111111111111111
ALLOWED_META_DISPLAY_PHONE_NUMBERS=5511999999999
# Deprecated compatibility fallback. Prefer ALLOWED_META_PHONE_NUMBER_IDS.
ALLOWED_META_PHONE_ID=
