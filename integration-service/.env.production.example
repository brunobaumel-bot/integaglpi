# IntegraGLPI production environment example
# Copy manually to the server .env and fill real values there only.
# Do not commit real tokens, passwords, secrets, signed URLs, VPN data or payloads.

NODE_ENV=production
INTEGRATION_SERVICE_PORT=3002

# PostgreSQL IntegraGLPI
DB_HOST=<postgres-host>
DB_PORT=5432
DB_NAME=<postgres-db-name>
DB_USER=<postgres-user>
DB_PASSWORD=<rotate-before-production>
DB_SSL=false

# GLPI REST API
GLPI_API_BASE_URL=https://<glpi-host>/apirest.php
GLPI_APP_TOKEN=<rotate-before-production>
GLPI_USER_TOKEN=<rotate-before-production>
GLPI_HTTP_TIMEOUT_MS=5000
GLPI_HTTP_RETRY_COUNT=1

# Meta WhatsApp
META_PHONE_NUMBER_ID=<production-phone-number-id>
META_ACCESS_TOKEN=<rotate-before-production>
META_APP_SECRET=<rotate-before-production-if-used>
META_VERIFY_TOKEN=<rotate-before-production>
META_MEDIA_MAX_BYTES=15728640

# Redis
REDIS_HOST=<redis-host>
REDIS_PORT=6379
CONTACT_CACHE_TTL_SECONDS=3600

# Internal PHP plugin -> integration-service auth
INTEGRATION_SERVICE_API_KEY=<rotate-before-production>
OUTBOUND_SEND_MODE=real

# Inactivity reminders/autoclose
INACTIVITY_AUTOCLOSE_ENABLED=false
INACTIVITY_REMINDER_MINUTES=3,5,10
INACTIVITY_AUTOCLOSE_MINUTES=30
INACTIVITY_JOB_INTERVAL_SECONDS=60

# AI Supervisor must remain disabled in production until a separate human gate.
AI_SUPERVISOR_ENABLED=false
AI_SUPERVISOR_PROVIDER=ollama
AI_SUPERVISOR_MODEL=<disabled-or-placeholder>
AI_SUPERVISOR_BASE_URL=http://127.0.0.1:11434/disabled-prod-ai
AI_SUPERVISOR_TIMEOUT_SECONDS=30
AI_SUPERVISOR_MAX_MESSAGES=30
AI_SUPERVISOR_MAX_CHARS=12000
AI_SUPERVISOR_DRY_RUN=true

# Logging
LOG_LEVEL=info
