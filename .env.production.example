NODE_ENV=production
PORT=3002
INTEGRATION_SERVICE_PORT=3002
INTEGRATION_SERVICE_API_KEY=change-me-use-at-least-32-characters
OUTBOUND_SEND_MODE=mock

GLPI_API_BASE_URL=https://sistema.example.com.br/apirest.php
GLPI_APP_TOKEN=change-me
GLPI_USER_TOKEN=change-me
GLPI_HTTP_TIMEOUT_MS=5000
GLPI_HTTP_RETRY_COUNT=1

META_APP_SECRET=change-me
META_VERIFY_TOKEN=change-me
META_ACCESS_TOKEN=change-me
META_PHONE_NUMBER_ID=000000000000000
META_MEDIA_MAX_BYTES=15728640

REDIS_HOST=redis-prod
REDIS_PORT=6379
CONTACT_CACHE_TTL_SECONDS=3600

DB_HOST=postgres-prod
DB_PORT=5432
DB_NAME=glpi_integaglpi_prod
DB_USER=glpi_integaglpi_prod
DB_PASSWORD=change-me
DB_SSL=false

AI_ENABLED=false
AI_PROVIDER=mock
AI_SERVICE_PORT=4001
